#!/usr/bin/env bash
#
# bootstrap installs things.

DOTFILES_ROOT="`pwd`"

set -e

info () {
  printf "  [ \033[00;34m..\033[0m ] $1"
}

user () {
  printf "\r  [ \033[0;33m?\033[0m ] $1 "
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
  echo ''
  exit
}

default_action=''

for arg in "$@"; do
  case "$arg" in
    --skip-all)      action_flag='skip_all';;
    --backup-all)    action_flag='backup_all';;
    --overwrite-all) action_flag='overwrite_all';;
    *) fail "Unknown argument: $arg";;
  esac
  if [ -n "$default_action" ] && [ "$default_action" != "$action_flag" ]; then
    fail "--skip-all, --backup-all, and --overwrite-all are mutually exclusive"
  fi
  default_action="$action_flag"
done

echo ''

link_files () {
  ln -s $1 $2
  success "linked $1 to $2"
}

install_dotfiles () {
  info 'installing dotfiles'

  overwrite_all=false
  backup_all=false
  skip_all=false

  [ "$default_action" = 'overwrite_all' ] && overwrite_all=true
  [ "$default_action" = 'backup_all' ]    && backup_all=true
  [ "$default_action" = 'skip_all' ]      && skip_all=true

  for source in `find $DOTFILES_ROOT -name \*.\*symlink`
  do
    # Recursively symlinking the files to home dir, also creating the necessary
    # dirs
    path_to_symlink=${source#$DOTFILES_ROOT}
    path_to_symlink=${path_to_symlink#/*/}  # take out the topical dir
    dest="$HOME"
    if [ `dirname $path_to_symlink` != "." ]
    then
      # At this point, $dest is the directory that the symlink will end up in
      dest="${dest}/`dirname $path_to_symlink`"
      mkdir -p "${dest}"
    fi
    if [ ${source##*.} == "dotsymlink" ]
    then
      dest="${dest}/.`basename \"${source%.*}\"`"
    else
      dest="${dest}/`basename \"${source%.*}\"`"
    fi

    if [ -L $dest ] || [ -f $dest ] || [ -d $dest ]
    then
      overwrite=false
      backup=false
      skip=false

      if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]
      then
        user "File already exists: `basename $source`, what do you want to do? [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -n 1 action

        case "$action" in
          o )
            overwrite=true;;
          O )
            overwrite_all=true;;
          b )
            backup=true;;
          B )
            backup_all=true;;
          s )
            skip=true;;
          S )
            skip_all=true;;
          * )
            ;;
        esac
      fi

      if [ "$overwrite" == "true" ] || [ "$overwrite_all" == "true" ]
      then
        rm -rf $dest
        success "removed $dest"
      fi

      if [ "$backup" == "true" ] || [ "$backup_all" == "true" ]
      then
        mv $dest $dest\.backup
        success "moved $dest to $dest.backup"
      fi

      if [ "$skip" == "false" ] && [ "$skip_all" == "false" ]
      then
        link_files $source $dest
      else
        success "skipped $source"
      fi

    else
      link_files $source $dest
    fi

  done
}

install_dotfiles

echo ''
echo '  All installed!'
